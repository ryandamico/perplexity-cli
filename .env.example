# Perplexity API key — get one at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cost confirmation threshold (default: 2.00)
# Searches with estimated cost above this amount require interactive confirmation.
# Use --yes to bypass for a single run.
# PERPLEXITY_COST_LIMIT=2.00
